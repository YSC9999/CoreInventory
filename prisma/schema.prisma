generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (PostgreSQL native) ---
enum Role {
  SUPER_ADMIN
  MANAGER
  WAREHOUSE_STAFF
}

enum TransactionType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum OperationStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELED
}

enum UnitOfMeasure {
  UNIT
  KG
  LITRE
  BOX
  METRE
}

// --- Organization & Users ---
model Organization {
  id         String      @id @default(cuid())
  name       String
  inviteCode String      @unique
  users      User[]
  warehouses Warehouse[]
  items      Item[]
  categories Category[]
  receipts   Receipt[]
  deliveries Delivery[]
  transactions Transaction[]
  createdAt  DateTime    @default(now())
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  password       String
  role           Role         @default(WAREHOUSE_STAFF)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  verified       Boolean      @default(false)
  receipts       Receipt[]    @relation("createdBy")
  deliveries     Delivery[]   @relation("createdBy")
  transactions   Transaction[] @relation("createdBy")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  @@index([organizationId])
}

// --- Warehouse Infrastructure ---
model Warehouse {
  id             String       @id @default(cuid())
  name           String
  shortCode      String
  address        String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations      Location[]
  receipts       Receipt[]
  deliveries     Delivery[]
  createdAt      DateTime     @default(now())

  @@unique([shortCode, organizationId])
  @@index([organizationId])
}

model Location {
  id          String        @id @default(cuid())
  name        String
  shortCode   String
  warehouseId String
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stocks      Stock[]
  fromTxns    Transaction[] @relation("FromLocation")
  toTxns      Transaction[] @relation("ToLocation")

  @@unique([shortCode, warehouseId])
  @@index([warehouseId])
}

// --- Products & Inventory ---
model Category {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Item {
  id             String         @id @default(cuid())
  sku            String
  name           String
  description    String?
  uom            UnitOfMeasure  @default(UNIT)
  minStock       Int            @default(0)
  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id])
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stocks         Stock[]
  receiptLines   ReceiptLine[]
  deliveryLines  DeliveryLine[]
  transactions   Transaction[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([sku, organizationId])
  @@index([organizationId])
  @@index([categoryId])
}

model Stock {
  id         String   @id @default(cuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Int      @default(0)

  @@unique([itemId, locationId])
  @@index([itemId])
  @@index([locationId])
}

// --- Receipts (Incoming) ---
model Receipt {
  id              String          @id @default(cuid())
  referenceNumber String          @unique
  warehouseId     String
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status          OperationStatus @default(DRAFT)
  notes           String?
  createdById     String
  createdBy       User            @relation("createdBy", fields: [createdById], references: [id])
  lines           ReceiptLine[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([warehouseId])
  @@index([createdById])
}

model ReceiptLine {
  id               String  @id @default(cuid())
  receiptId        String
  receipt          Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  itemId           String
  item             Item    @relation(fields: [itemId], references: [id])
  quantity         Int
  costPrice        Float?

  @@index([receiptId])
  @@index([itemId])
}

// --- Deliveries (Outgoing) ---
model Delivery {
  id              String          @id @default(cuid())
  referenceNumber String          @unique
  warehouseId     String
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status          OperationStatus @default(DRAFT)
  notes           String?
  createdById     String
  createdBy       User            @relation("createdBy", fields: [createdById], references: [id])
  lines           DeliveryLine[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([warehouseId])
  @@index([createdById])
}

model DeliveryLine {
  id         String   @id @default(cuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  quantity   Int

  @@index([deliveryId])
  @@index([itemId])
}

// --- Audit Trail ---
model Transaction {
  id             String           @id @default(cuid())
  itemId         String
  item           Item             @relation(fields: [itemId], references: [id])
  type           TransactionType
  quantity       Int
  fromLocationId String?
  fromLocation   Location?        @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     Location?        @relation("ToLocation", fields: [toLocationId], references: [id])
  notes          String?
  createdById    String
  createdBy      User             @relation("createdBy", fields: [createdById], references: [id])
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([organizationId])
  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([createdById])
  @@index([createdAt])
}
